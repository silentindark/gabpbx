GABPBX_FILE_VERSION(__FILE__, "$Revision: 1000 $")

static char *app = "GABBilling";

#define VAR_SIZE 64

static char proxyname[80];
struct ast_app *dial_app            = NULL;
struct ast_app *hangup_app          = NULL;
struct ast_app *sipaddheader_app    = NULL;
struct ast_app *sipremoveheader_app = NULL;
struct ast_app *set_app             = NULL;

static int dial(struct ast_channel *chan, void *data)
{
	int ret;

	if (dial_app) {
		ret = pbx_exec(chan, dial_app, data);
	} else {
		ast_log(LOG_WARNING, "Could not find application Dial\n");
		ret = -2;
	}

	return ret;
}

