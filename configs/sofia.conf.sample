; (SEPARATE per-peer + [general] parsers) + chan_sip.c:747 verbatim static
; unsigned int global_autoframing + chan_sip.c:29469 verbatim default-init = 0
; + sip.h:1018 + L1231 verbatim bit field declarations on sip_pvt + sip_peer
; + 5 inheritance sites L5942 + L8547 + L17021 + L17157 + L28459 + chan_sip.c
; :10415 verbatim use site at SDP parse direction (honor peer-advertised
; ptime when set) + chan_sip.c:12663 verbatim use site at SDP generate
; direction (force config ptime when clear + incoming) + 3 display sites
; (sip show peer L18728 + sip show user L18963 + sip show settings L19403).
