;
; Sofia-SIP Channel Driver Configuration for GABpbx
;
; This file configures chan_sofia, a SIP channel driver built on
; the sofia-sip NUA API. The format is compatible with sip.conf.
;
; Dial string: SOFIA/peername/extension
;   e.g. SOFIA/test100   SOFIA/remote-pbx/1234
;
; Realtime: chan_sofia uses "sippeers" family (same as chan_sip).
; Configure in extconfig.conf:
;   sippeers => sqlite3,/var/lib/gabpbx/sqlite3.db
;
; All commented options below are documented features. The driver has no
; "accepted-but-no-effect" options at this point — every parser key listed
; below maps to a working code path. Aliases noted in §reference.
;

[general]
;
; Default context for incoming calls
;
context=default

;
; Address and port to bind to (UDP+TCP listener)
; Alias: udpbindaddr accepts "host:port" form (sip.conf compatibility)
;
bindaddr=0.0.0.0
bindport=5080

;
; Realtime sipregs separate-table (post-T56 sipregs parity, 2026-04-27)
; ---------------------------------------------------------------------
; chan_sofia auto-detects when extconfig.conf wires the `sipregs` realtime
; family separately from `sippeers`. When detected, registration state
; (ipaddr/port/regseconds/fullcontact/etc.) writes to sipregs while per-peer
; config (secret/context/dtmfmode/etc.) stays in sippeers — chan_sip parity.
; Useful for federated / load-balanced clusters where registration state
; needs cluster-shared storage. NO sofia.conf option keys required —
; pure extconfig.conf-driven auto-detection via ast_check_realtime("sipregs").
; See doc/realtime_sipregs.txt for schema + setup details.
;
; Authentication realm (used in digest challenges; default: gabpbx)
; chan_sofia issues WWW-Authenticate with qop="auth" and supports MD5 plus
; SHA-256 digest verification. Falls back to RFC 2069 form when client omits
; qop in Authorization (permissive backward compat). Per-peer nc replay window
; prevents same-nc reuse. Nonce TTL defaults to 3600s and can be overridden with
; nonce_ttl_seconds below; expired nonce triggers 401 + stale=true.
;
realm=gabpbx

;
; Allow guest calls (calls from unknown peers)
; Default: yes
;
allowguest=yes

;
; SRV lookup for outbound calls
; Default: yes
;
srvlookup=yes

;
; --- TLS / WS / WSS listeners (T36) — optional ---
; tlsbindaddr  = 0.0.0.0
; tlsbindport  = 5061                         ; non-zero enables TLS listener
; tlscertfile  = /etc/gabpbx/keys             ; DIR containing agent.pem (combined cert+key); alias: tlscertdir
;
; ws-binding for browser SIP UAs (no TLS)
; wsbindaddr   = 0.0.0.0
; wsbindport   = 5066                         ; non-zero enables WS listener
;
; wss-binding (recommended for production browser UAs; reuses tlscertfile)
; wssbindaddr  = 0.0.0.0
; wssbindport  = 7443                         ; non-zero enables WSS listener
;
; NOTE: TLS expects agent.pem (combined cert+key) + cafile.pem (CA cert) in tlscertfile dir.
; WSS additionally needs wss.pem + ca-bundle.crt — chan_sofia AUTO-LINKS these from
; agent.pem + cafile.pem at startup when wssbindport is set, so operators only manage
; the two TLS files. Generate self-signed for testing:
;   openssl req -x509 -newkey rsa:2048 -keyout key.pem -out cert.pem -days 365 -nodes -subj "/CN=mypbx"
;   cat cert.pem key.pem > /etc/gabpbx/keys/agent.pem
;   cp cert.pem /etc/gabpbx/keys/cafile.pem
; T36: WebRTC media (DTLS-SRTP/ICE/BUNDLE) is Stage B — signaling-only here.
;
; --- WS+WSS deployment guidance (post-T56 Task #2 D-3 SS2 operator-honest expansion) ---
;
; (1) ORIGIN HEADER VALIDATION (RFC 7118 §4.1.4) — DELEGATED TO REVERSE-PROXY:
;     The underlying sofia-sip ws.c does NOT validate the WebSocket Origin
;     header. For cross-origin protection, deploy chan_sofia BEHIND a reverse
;     proxy (nginx, Caddy, HAProxy) that enforces an Origin allowlist. Example
;     nginx config snippet:
;       map $http_origin $origin_ok { default 0; "https://pbx.example.com" 1; }
;       server {
;         listen 443 ssl http2;
;         location /sip {
;           if ($origin_ok = 0) { return 403; }
;           proxy_pass http://127.0.0.1:5066;       ; chan_sofia wsbindport
;           proxy_http_version 1.1;
;           proxy_set_header Upgrade $http_upgrade;
;           proxy_set_header Connection "upgrade";
;           proxy_set_header Host $host;
;           proxy_set_header X-Forwarded-For $remote_addr;
;         }
;       }
;     chan_sofia exposes wsbindport on localhost; nginx terminates TLS + enforces
;     Origin. Operator-honest disclosure: chan_sofia does NOT enforce Origin
;     directly; reverse-proxy is the recommended chan_sofia deployment pattern.
;
; (2) Sec-WebSocket-Protocol — LENIENT ECHO (sofia-sip ws.c:304/315):
;     sofia-sip echoes any client-offered Sec-WebSocket-Protocol value without
;     strict validation. RFC 7118 §4.2 prescribes the literal "sip" subprotocol;
;     chan_sofia accepts any echo (lenient). Operators relying on strict
;     subprotocol negotiation should enforce at the reverse-proxy via
;     `if ($http_sec_websocket_protocol != "sip") { return 400; }` or similar.
;     For signaling-only deployments behind a reverse-proxy, lenient acceptance
;     is safe (the reverse-proxy gates connection establishment).
;
; (3) BROWSER SIP STACK EXAMPLES — sip.js + JsSIP (non-WebRTC media path):
;     chan_sofia D-3 ships SIP signaling over WS+WSS only. Browser clients
;     using sip.js or JsSIP libraries with plain RTP / SDES-SRTP media work
;     out-of-the-box. WebRTC-mandated DTLS-SRTP + ICE + BUNDLE media remains
;     Stage B (D-2 future task — see migration path below).
;
;     sip.js (https://sipjs.com/) minimal config:
;       const ua = new SIP.UserAgent({
;         uri: SIP.UserAgent.makeURI("sip:alice@pbx.example.com"),
;         transportOptions: {
;           server: "wss://pbx.example.com:7443",
;           connectionTimeout: 10
;         },
;         authorizationUsername: "alice",
;         authorizationPassword: "secret"
;       });
;       ua.start();
;     Cert-pinning: production deployments should pin the WSS cert via the
;     browser's HSTS/HPKP infrastructure (handled by reverse-proxy TLS).
;
;     JsSIP (https://jssip.net/) minimal config:
;       const socket = new JsSIP.WebSocketInterface("wss://pbx.example.com:7443");
;       const config = {
;         sockets: [socket],
;         uri: "sip:alice@pbx.example.com",
;         password: "secret"
;       };
;       const ua = new JsSIP.UA(config);
;       ua.start();
;
; (4) D-2 FUTURE-TASK MIGRATION PATH (full WebRTC media):
;     Current D-3 scope: SIP signaling over WS+WSS only; media-layer remains
;     plain RTP/SAVP (SDES-SRTP per RFC 4568) compatible with sip.js + JsSIP
;     browser SIP stacks WITHOUT WebRTC mandate.
;
;     WebRTC compliance limitations under D-3:
;       - NO DTLS-SRTP (RFC 5763/5764) — chan_sofia uses SDES key exchange
;       - NO ICE (RFC 8445) candidate gathering — chan_sofia uses host RTP only
;       - NO BUNDLE / RTCP-MUX (RFC 8843) — chan_sofia uses separate RTCP port
;     Operators MUST use non-WebRTC-mandate browser SIP stacks (sip.js / JsSIP
;     with `mediaConstraints` set to plain RTP) for media. Native WebRTC
;     `RTCPeerConnection` clients require D-2 (multi-month dedicated project,
;     ~10,000+ LoC port from gabpbx77 reference + sofia-sip media-engine
;     integration). D-2 deferred indefinitely pending operator commitment.
;
;     If full WebRTC is required, operator options:
;       (a) deploy a WebRTC-to-SIP gateway (Janus, FreeSWITCH mod_verto) in
;           front of chan_sofia — gateway handles DTLS-SRTP/ICE/BUNDLE,
;           chan_sofia speaks plain RTP/SAVP behind it
;       (b) wait for chan_sofia D-2 (no committed timeline)
;       (c) use the existing chan_sip + res_pjsip stack on a parallel deploy
;
; (5) chan_sofia SURPASS over chan_sip on WS+WSS dimensions:
;     chan_sip has NO WebSocket support whatsoever (verified — 0 hits in
;     chan_sip.c for websocket/RFC 7118/wsbindport). chan_sofia D-3 ships:
;       - WS + WSS listeners (T36 ec1bcd9)
;       - transport=ws / transport=wss per-peer parser (D-3 SS1)
;       - sip show peer / sip show settings / AMI SIPshowpeer Transport
;         display extension (D-3 SS1, 28-FIELD MILESTONE on sip show settings)
;       - LOG_WARNING on unknown transport= values (chan_sip silent fallback)
;       - WSS auto-cert-link from agent.pem + cafile.pem (T36)
;       - this operator-honest deployment guidance (D-3 SS2)
;     This is Pattern 12 chan_sofia-feature-not-in-chan_sip-at-all sub-pattern
;     33rd-instance — chan_sip operators with browser-UA needs migrate to
;     chan_sofia for WS+WSS support.
;
; --- end WS+WSS deployment guidance ---

;
; External address for NAT traversal — substituted into SDP o= and c= lines
; for peers OUTSIDE the localnet ranges below. Lets WAN clients reach RTP
; through 1:1 NAT or SBC. RTP socket bind unchanged (still local interface).
; Alias: externhost (separate semantics post-T56 NAT parity fill 2026-04-27 —
; externhost = DDNS hostname (lazy-resolved to externaddr per externrefresh);
; externaddr = static IP). Backwards-compat: externaddr=hostname auto-detected
; + routed to externhost path (lenient parser; existing operator scripts unchanged).
;externaddr=203.0.113.1
;externhost=mypbx.dyndns.net   ; DDNS WAN hostname; chan_sofia re-resolves periodically per externrefresh
;externrefresh=10              ; DNS-refresh interval in seconds (default 10; chan_sip parity)
;externtcpport=5060            ; external TCP port for outbound headers (default 5060; 0 = use externaddr port)
;externtlsport=5061            ; external TLS port for outbound headers (default 5061)
;
; Local network ranges — peers matching ANY localnet keep the local socket
; address in SDP. Peers outside ALL ranges get externaddr substitution.
; Repeat the directive for multiple ranges (CIDR notation).
;localnet=192.168.0.0/24
;localnet=10.0.0.0/8

;
; Default qualify settings for all peers
; These are used when peer has qualify=yes but no explicit values
;
;qualify=yes
;qualifyfreq=60
;qualifytimeout=3

;
; Busy-on-active: reject new calls with 486 Busy Here when any device on
; this account is already in a call. Default: no.
;
;busy_on_active = no
;
; Max simultaneous registered devices per peer.
; Range [1, 6], default 6, hard ceiling 6.
;
;max_contacts   = 6

;
; --- Identity headers (post-T56 identity-headers parity, RFC 3325 + RFC 3323) ---
; chan_sip drop-in defaults — peers omitting callingpres / sendrpid / trustrpid
; inherit from this [general] block. Per-peer keys override.
;
; callingpres   - default presentation for outbound calls. Accepted values mirror
;                 chan_sip exactly (see callerid.h AST_PRES_* table):
;                   allowed_not_screened   (DEFAULT — Allowed, Not Screened)
;                   allowed_passed_screen  (Allowed, Passed Screen)
;                   allowed_failed_screen  (Allowed, Failed Screen)
;                   allowed                (Allowed, Network Number)
;                   prohib_not_screened    (Prohibited, Not Screened)
;                   prohib_passed_screen   (Prohibited, Passed Screen)
;                   prohib_failed_screen   (Prohibited, Failed Screen)
;                   prohib                 (Prohibited, Network Number)
;                   unavailable
; sendrpid      - outbound RPID/PAI emission mode. Default: no.
;                   no    - no PAI / no RPID (chan_sip default)
;                   pai   - emit P-Asserted-Identity (RFC 3325)
;                   rpid  - emit Remote-Party-ID (legacy RFC draft)
; trustrpid     - trust inbound PAI / RPID and apply caller-id from them.
;                 Default: no. Set yes only for trusted upstream proxies / SBCs.
;
;callingpres    = allowed_not_screened
;sendrpid       = no
;trustrpid      = no

;
; --- Call-limit (post-T56 call-limit parity) ---
; Trunk capacity control — essential for PBX-to-PBX deployments. chan_sip parity
; key names: callcounter / call-limit / busylevel. Inbound INVITE rejected with
; 480 Temporarily Unavailable (Call limit) when inUse >= call-limit; outbound dial
; returns AST_CAUSE_USER_BUSY (486 Busy Here equivalent).
;
; callcounter   - shorthand: yes -> unlimited counter participation (call-limit
;                 = INT_MAX, 480 enforcement disabled but inUse/inRinging/onHold
;                 still tracked for sip show inuse + AMI). Default: no.
; call-limit    - hard cap on simultaneous calls; 0 = unlimited. Default: 0.
;                 (alias accepted: call_limit — for operator-friendly drop-in)
; busylevel     - soft cap; outbound returns BUSY when inUse >= busy_level
;                 (allows graceful overflow before hard reject). Default: 0.
;
;callcounter    = no
;call-limit     = 0
;busylevel      = 0

;
; --- allowtransfer per-peer (post-T56 chan_sip parity, drop-in REFER policy) ---
; Gate inbound SIP REFER (call-transfer requests). When set to "no"/"false",
; chan_sofia rejects every REFER from the peer with 603 Declined (policy) and
; never processes the transfer body. Default "yes" matches chan_sip backwards-
; compat ("Merrily accept all transfers" — chan_sip.c:29476). Set per-peer in
; [peer] section to override; or set this default to "no" plus opt-in trusted
; peers individually (typical PBX-hardening posture).
;
; Operator-honest disclosure: REFER is an attack surface — a misbehaving or
; compromised peer can use REFER to redirect active calls (call spam, redirect
; to attacker-controlled URIs, premium-rate fraud). Per-peer allowtransfer=no
; on untrusted/external trunks closes that vector while keeping internal
; extensions free to use *2 attended-transfer / blind-transfer keys.
;
; chan_sofia surpass: when REFER is rejected by this gate, an AMI event
; "TransferRejected" fires (Channel + Uniqueid + Peer + ReferTo + Reason)
; for real-time NMS monitoring of REFER-abuse attempts. chan_sip silently
; rejects with history-only logging (no AMI signal).
;
;default_allowtransfer = yes    ; yes = allow REFER (chan_sip default); no = reject 603 Declined (policy)
;allowtransfer         = yes    ; bare key alias accepted in [general] (chan_sip MOH-style leniency)

;
; --- allowsubscribe (post-T56 chan_sip parity, drop-in SUBSCRIBE policy) ---
; REQUEST-EVENT GATING dimension #6 sibling to allowtransfer — gates inbound
; SIP SUBSCRIBE (presence/MWI/dialog event subscriptions). When [general]
; allowsubscribe=no AND every peer has allowsubscribe=no, chan_sofia rejects
; every SUBSCRIBE upfront with 403 Forbidden (policy) — chan_sip parity at
; chan_sip.c:25856 global ban gate. Per-peer allowsubscribe=no rejects per-peer
; with the same 403 string (chan_sip parity at chan_sip.c:25940). Default yes
; per chan_sip drop-in (sip.h:478 SIP_PAGE2_ALLOWSUBSCRIBE default TRUE — "Default
; for all devices: TRUE"). chan_sip operator scripts with allowsubscribe= migrate
; verbatim zero-rewrite.
;
; chan_sofia surpass: when SUBSCRIBE is rejected by this gate, an AMI event
; "SubscribeRejected" fires (Peer + Event + Reason:AllowSubscribeClosed +
; RemoteAddr + ChannelType:SIP) for real-time NMS monitoring of subscribe-abuse
; attempts. chan_sip silent on these paths. Note: GabPBX has no
; EVENT_FLAG_SECURITY class, so the event ships under EVENT_FLAG_SYSTEM matching
; existing chan_sofia AMI events.
;
;allowsubscribe = yes    ; default; chan_sip drop-in (sip.h:478 default TRUE)

;
; --- regexten + regextenonqualify (post-T56 chan_sip parity, drop-in registration-coupled dialplan) ---
; Auto-add a dialplan extension when a peer registers; auto-remove when the peer
; unregisters or (optionally) when qualify reports the peer unreachable. Common
; uses: presence-monitor hint extensions tied to peer registration state, dialplan
; dispatch lines that should only exist while the peer is online.
;
; regcontext = MASTER SWITCH. Names the dialplan context that holds auto-added
;   extensions. EMPTY (default) DISABLES THE ENTIRE MECHANISM — without regcontext
;   set, per-peer regexten= is parsed and stored but never affects the dialplan.
;   chan_sip parity at chan_sip.c:5198-5199 (register_peer_exten outer gate).
;
; regextenonqualify = couple regexten add/remove to qualify state transitions.
;   When yes, the extension is also removed when qualify marks the peer
;   UNREACHABLE and re-added when REACHABLE — operators presence-monitor reachability
;   via dialplan hints. Default no per chan_sip sip.h:215 DEFAULT_REGEXTENONQUALIFY.
;
; Per-peer regexten= override (in [peer] section) accepts:
;   - Single extension: regexten=200            -> '200' added in regcontext
;   - Multi-extension via &: regexten=200&201   -> '200' AND '201' added
;   - Per-ext context override: regexten=200@hints&201@otherctx
;   - Empty per-peer regexten with regcontext set: peer->name used as fallback extension
;     (e.g., regcontext=hints + peer alice with no regexten= -> 'alice' added in [hints])
;
; chan_sofia surpass over chan_sip: AMI RegextenOnQualifyTransition event fires on
; every add/remove (Peer + Extension + Context + Direction:add|remove) so NMS systems
; can monitor regexten dialplan-mutation in real time. chan_sip silently fires
; register_peer_exten with no AMI signal.
;
; KNOWN LIMITATION (chan_sofia divergence): chan_sip's cleanup_stale_contexts on
; reload (when regcontext value changes) is NOT implemented — chan_sofia is
; non-unloadable per T40 (sofia-sip same-thread-as-create assert), so operators
; restart gabpbx for regcontext value changes. Stale extensions from the prior
; regcontext value remain until restart. Operators changing regcontext rarely
; (typically once at deploy time) are unaffected.
;
;regcontext        = hints      ; dialplan context for auto-added register extensions
;regextenonqualify = no         ; couple regexten add/remove to qualify state transitions

;
; --- subscribecontext (post-T56 chan_sip parity, drop-in PARSE-COMPAT today; effect-pending) ---
; In chan_sip, subscribecontext routes inbound SIP SUBSCRIBE method dispatches
; to a SEPARATE dialplan context (instead of the peer's voice-call context).
; Operators isolate presence/MWI signaling-state-only logic from voice dialplan.
;
; Per-peer subscribecontext= overrides default_subscribecontext from [general].
; chan_sip operator scripts copying these config keys copy verbatim to chan_sofia.
;
; KNOWN LIMITATION (chan_sofia today, parsed-but-effect-pending): chan_sofia's
; SUBSCRIBE-handling path (sofia_process_subscribe) currently only routes the
; message-summary event-package to the MWI handler (T55) + auto-202s all other
; events. There is no general SUBSCRIBE-to-dialplan dispatch infrastructure yet,
; so a configured subscribecontext value is parsed + persisted + displayed (sip
; show peer Subscr.Cont. line + realtime sippeers column) but does not yet route
; SUBSCRIBE dispatch. The pivot-site override (chan_sip.c:16427-16429
; equivalent) lands paired with a future presence/dialog event-package handler
; task. Operators get drop-in config-parse compat today; runtime effect arrives
; with the presence handler.
;
; This honest-disclosure pattern mirrors the regexten task's cleanup_stale_contexts
; KNOWN LIMITATION (chan_sofia non-unloadable per T40 architectural).
;
;default_subscribecontext = presence    ; [general] default; peers inherit when their subscribecontext= is unset
;subscribecontext         = presence    ; per-peer override (in [peer] section)

;
; --- Registration TTL bounds + 423 Interval Too Brief (post-T56 chan_sip parity, RFC 3261 §10.2.8) ---
; Govern peer-requested REGISTER expires interval. Prevents (a) resource exhaustion
; from peers re-registering aggressively at very short TTLs, (b) over-stale
; registrations that delay dead-peer detection at very long TTLs.
;
; Semantics (chan_sip parity at chan_sip.c:25699-25702):
;   - peer-requested expires > maxexpiry: silently capped to maxexpiry; 200 OK accepts
;   - peer-requested expires < minexpiry (and > 0): rejected with 423 Interval Too Brief
;     + Min-Expires:<minexpiry> header (RFC 3261 §10.2.8); peer retries with valid value
;   - peer-requested expires == 0: bypasses bounds (unregister) — standard processing
;   - defaultexpiry: fallback when peer omits Expires header from REGISTER + initial
;     value for peer->expiresecs at sofia_peer_alloc when peer config omits expiresecs=
;
; chan_sip historical TYPO-TOLERANCE (drop-in compat preserved): chan_sip parser
; accepts BOTH spellings of each key — chan_sofia mirrors. Operators with historical
; typo'd configs (minexpirey/maxexpirey/defaultexpirey extra-e form) reload cleanly.
;
; chan_sofia surpass over chan_sip silent reject: AMI RegisterIntervalRejected event
; fires on every 423 reject (Peer + RequestedExpires + MinExpires + ResponseCode +
; Reason: BelowMinExpiry) so NMS systems gain real-time signal for REGISTER-storm
; or aggressive-re-register pattern monitoring. chan_sip emits no AMI signal (only
; LOG_NOTICE).
;
; KNOWN DIVERGENCE (Option A dual-scope): chan_sip uses defaultexpiry as
; [general]-only key. chan_sofia historically also accepts defaultexpiry as a
; PER-PEER alias for expiresecs= (legacy chan_sofia operators). Both scopes are
; supported today: [general] defaultexpiry sets sofia_cfg.default_expiry (chan_sip
; parity); per-peer expiresecs= or defaultexpiry= overrides per-peer (chan_sofia
; legacy). Operators with chan_sip [general] defaultexpiry configs migrate verbatim;
; chan_sofia operators using per-peer alias see no behavior change.
;
;minexpiry      = 60       ; minimum REGISTER expires (seconds); under-min rejected with 423
;maxexpiry      = 3600     ; maximum REGISTER expires (seconds); over-max silently capped
;defaultexpiry  = 120      ; fallback expires when peer omits Expires header; also peer->expiresecs default
;
; Typo-tolerance variants accepted (chan_sip parity): minexpirey / maxexpirey / defaultexpirey

;
; --- usereqphone (post-T56 chan_sip parity, RFC 3966 telephone-uri) ---
; Append ;user=phone parameter to outbound Request-URI + From URI when peer's
; user-part matches digit-only pattern (with optional leading +). Required by
; PSTN gateways that expect RFC 3966 telephone-uri formatting for E.164 numbers.
;
; Mechanism (chan_sip parity at chan_sip.c:12836-12853 + L28781-L28782 + L29660-L29661):
;   - peer username "15555551212" + usereqphone=yes → URI "sip:15555551212@host;user=phone"
;   - peer username "+15555551212" + usereqphone=yes → URI "sip:+15555551212@host;user=phone"
;   - peer username "alice" (alphanumeric) + usereqphone=yes → URI "sip:alice@host" (no parameter; pattern fails)
;   - peer username "15555551212" + usereqphone=no → URI "sip:15555551212@host" (default; opt-in)
;
; Per-peer usereqphone= overrides [general] default. chan_sip operator scripts copy verbatim.
;
; chan_sofia ARCHITECTURAL ADVANTAGE over chan_sip: single-helper internal extension —
; sofia_resolve_peer_target (Request-URI builder) + sofia_build_from (From-URI builder)
; each have one extension site that catches all callsites (sofia_request_call INVITE +
; sofia_process_refer transfer + sofia_qualify_peer + sofia_call SDP/no-SDP +
; fork-children). chan_sip duplicates the digit-pattern check at each per-message
; URI-build site.
;
; chan_sofia surpass: 3-state CLI inheritance display ('User=Phone: yes (from [general])'
; when peer inherits default; raw 'yes'/'no' when peer-set explicitly).
;
;default_usereqphone = no    ; [general] default; peers inherit when their usereqphone= is unset
;usereqphone         = no    ; per-peer override (in [peer] section)

;
; --- maxforwards (post-T56 chan_sip parity, RFC 3261 §20.22 Max-Forwards) ---
; Initial value of Max-Forwards header on outbound INVITE/REGISTER. Decremented
; by each proxy hop; reaching 0 returns 483 Too Many Hops (loop-detection).
; Operators with stateful proxy chains may lower from default 70 to 20-30.
;
; chan_sip parity at chan_sip.c:30011-30015 ([general]) + L28878-28883 (per-peer);
; default DEFAULT_MAX_FORWARDS=70 (sip.h:60 verbatim, RFC 3261 §20.22). 1-255 bounds
; enforced; invalid values clamp to default with LOG_WARNING.
;
; chan_sofia surpass: 3-state CLI inheritance display in sip show peer
; ('Max forwards: <value> (from [general])' when peer inherits default; raw value
; when peer-set explicitly).
;
; Emitted via sofia-sip native SIPTAG_MAX_FORWARDS_STR at all outbound nua_invite +
; nua_register callsites (8 sites total). Pattern 16 sofia-sip-native 6th-instance.
;
;maxforwards = 70    ; [general] default OR per-peer override (1-255 valid range)

;
; --- t1min (post-T56 chan_sip parity, RFC 3261 §17.1.1.2 T1 retry-timer minimum) ---
; Minimum SIP transaction retry-timer T1 in milliseconds. Default 100ms per
; chan_sip parity (sip.h:217 DEFAULT_T1MIN). RFC 3261 §17.1.1.2 default is 500ms;
; chan_sip overrides to lower 100ms minimum bound. sofia-sip honors via NTATAG_SIP_T1
; at nua_create — global NTA-layer setting; all transactions inherit.
;
; Operationally: lower t1min means faster retransmission detection on healthy networks
; (better UX); higher t1min reduces retransmission storms on high-latency networks.
;
; KNOWN LIMITATION: per-peer dynamic T1 = max(peer->lastms, t1min) chan_sip parity
; (chan_sip.c:6024+L17056) DEFERRED per Pattern 15 — requires per-handle nua_set_hparams
; override at outbound nua_invite per dialog; complex per-peer state-tracking via
; qualify-RTT. Future task when operator demand surfaces.
;
;t1min = 100    ; minimum T1 retry-timer in milliseconds (chan_sofia minimum 10ms)

;
; --- relaxdtmf + prematuremedia (post-T56 chan_sip parity, [general] media-layer flags) ---
;
; relaxdtmf — toggle DSP_DIGITMODE_RELAXDTMF flag in ast_dsp digit detection.
;   When yes, ast_dsp uses relaxed threshold for DTMF tone detection — helps detect
;   DTMF on poor-quality lines (high jitter / packet loss / low-volume tones) at the
;   cost of more false positives (audio frequencies near DTMF being mis-detected as
;   keypresses). Default no per chan_sip parity at chan_sip.c:29518. Only effective
;   when peer dtmfmode=inband (chan_sofia DSP allocated by sofia_enable_dsp_detect
;   only for inband DTMF mode).
;
; prematuremedia — IMPORTANT: INVERTED-SEMANTIC chan_sip-quirk preserved per drop-in
;   compat. Internal variable name `prematuremediafilter` reveals the actual semantic:
;     - prematuremedia=yes (DEFAULT) → filter ON → 183 Session Progress SUPPRESSED
;       even on explicit dialplan Progress() call. Early-media frames blocked.
;     - prematuremedia=no → filter OFF → 183 emitted on Progress(); early-media flows.
;   Operator-confusing-but-chan_sip-faithful: yes reads as "allow" but actually MEANS
;   "filter/suppress". chan_sip.c:7298 + L29458 verbatim parity (default TRUE = filter
;   ON). chan_sip operator scripts copying prematuremedia= work identically here.
;
;relaxdtmf       = no    ; default; yes = relaxed DTMF detection (poor-quality lines)
;prematuremedia  = yes   ; default; yes = SUPPRESS 183 (filter ON); no = ALLOW 183 (filter OFF)

;
; --- registertimeout + registerattempts (post-T56 chan_sip parity, outbound REGISTER retry control) ---
; Application-level scheduled-retry control for outbound REGISTER (when chan_sofia
; operates as UAC registering to upstream registrars via register=> directive).
;
; registertimeout — seconds between retry passes (sofia_reg_thread sleep interval).
;   chan_sip parity at chan_sip.c:14217 + L29799-29803. Default 20s per
;   sip.h:59 DEFAULT_REGISTRATION_TIMEOUT verbatim. atoi + clamp-to-default if <1.
;
; registerattempts — maximum scheduled-retry count per peer (0 = unlimited).
;   chan_sip parity at chan_sip.c:14092 + L29804-29805. Default 0 (unlimited)
;   per chan_sip global_regattempts_max static-zero init. When set, registration
;   gives up after N failed attempts (auth-challenge or scheduled re-register).
;
; SEMANTIC NOTE: These are APPLICATION-LEVEL retry-policy flags, NOT sofia-sip
; per-transaction retry (NUTAG_RETRY_COUNT) which operates at a different
; semantic layer (transaction-internal retry on 5xx/ICMP-unreachable within a
; single attempt). chan_sip operator-facing semantic preserved verbatim.
;
;registertimeout  = 20    ; seconds between retry attempts; default 20s
;registerattempts = 0     ; maximum retries; 0 = unlimited (default; chan_sip parity)

;
; --- directrtpsetup (post-T56 chan_sip parity, EXPERIMENTAL — PARSE-COMPAT-ONLY) ---
; chan_sip experimental feature (default DISABLED per chan_sip.c:29449
; verbatim "Experimental feature, disabled by default"). When enabled in
; chan_sip, allows early RTP bridge before call answers — operationally niche.
;
; KNOWN LIMITATION (Pattern 12 honest-disclosure 8th-instance): chan_sofia
; PARSE-COMPAT-ONLY ship — field is parsed + stored + reload-clean for
; operators with chan_sip configs containing directrtpsetup=, but the
; full-feature early-RTP-bridge wire-in is DEFERRED. Reasoning: chan_sip
; itself defaults the feature DISABLED and labels it experimental; no current
; operator driver for full-feature ship. Future task IF operator demand
; surfaces. Drop-in PARSE-COMPAT primary value preserved (chan_sip operator
; scripts containing directrtpsetup=no — default — reload cleanly).
;
;directrtpsetup = no    ; default; experimental — PARSE-COMPAT-ONLY today (effect-deferred)

;
; --- alwaysauthreject (post-T56 chan_sip parity, security-critical) ---
; When yes (default), REGISTER from an unknown peer + MWI SUBSCRIBE for an
; unknown mailbox both return 401 Unauthorized with a bogus digest challenge
; instead of 403/404. RFC 3261 §22.4 username-enumeration prevention: an
; attacker probing for valid SIP accounts cannot distinguish "peer exists with
; bad password" from "peer does not exist". Default is yes per chan_sip
; sip.h:213 DEFAULT_ALWAYSAUTHREJECT=TRUE — drop-in security baseline; chan_sip
; operator scripts containing alwaysauthreject=yes/no migrate verbatim.
; chan_sofia surpass: every triggered 401 also emits an AMI AuthFailure event
; (Peer:UNKNOWN + Method + Reason + RemoteAddr) so an NMS can detect
; brute-force probing in real time (chan_sip is silent on the same paths —
; operators must grep authpedantic LOG_NOTICE). Note: GabPBX has no
; EVENT_FLAG_SECURITY class, so the event ships under EVENT_FLAG_SYSTEM
; matching existing chan_sofia AMI events; subscribe via system permission.
; chan_sip parity: chan_sip.c:29699-29700 ([general] parser) + sip.h:213.
;
;alwaysauthreject = yes    ; default; RFC 3261 §22.4 username-enumeration prevention

;
; --- compactheaders (post-T56 chan_sip parity, PARSE-COMPAT-ONLY) ---
; chan_sip emits short-form SIP header aliases (m=Contact, t=To, f=From, etc.)
; via find_alias per-header translation at message-build time (chan_sip.c:10716)
; when this flag is yes. Default off per sip.h:194 DEFAULT_COMPACTHEADERS=FALSE.
;
; KNOWN LIMITATION (Pattern 12 honest-disclosure 12th-instance): chan_sofia
; PARSE-COMPAT-ONLY ship — value is parsed + stored + reload-clean for operators
; with chan_sip configs containing compactheaders=, but the full-feature
; compact-emit wire-in is DEFERRED. ROOT CAUSE: sofia-sip ZERO native compact-emit
; gate (verified across nta_tag.h + nua_tag.h + sip_tag.h — no NUTAG_USE_COMPACT
; / SIPTAG_COMPACT / use_compact). chan_sofia delegates message-build to
; sofia-sip layer below the per-header-alias-rewrite point; no interception
; available without invasive sofia-sip patch.
;
; This is the FIRST Pattern 12 instance with sofia-sip-library-feature-absence
; root-cause (prior 11 instances were operator-driver-deferral or
; chan_sip-architectural-divergence). Future-fix path: upstream sofia-sip
; exposes NUTAG_USE_COMPACT or equivalent → chan_sofia adds wire-in at
; nua_create / per-message tag list. Until then, chan_sofia outbound messages
; emit long-form SIP headers regardless of compactheaders setting.
;
;compactheaders = no    ; default; PARSE-COMPAT-ONLY today (effect-deferred per sofia-sip-library-absence)

;
; --- disallowed_methods (post-T56 chan_sip parity, PARSE-COMPAT-ONLY) ---
; Comma-separated list of SIP method names blocked from outbound Allow header.
; Operators block unwanted methods (e.g. PUBLISH, MESSAGE, OPTIONS) that should
; never be accepted from upstream peers. Both [general] and per-peer scope
; supported (per-peer overrides [general]).
;
; KNOWN LIMITATION (Pattern 12 honest-disclosure 9th-instance): chan_sofia
; PARSE-COMPAT-ONLY ship — value is parsed + stored as STRING and reload-clean
; for operators with chan_sip configs containing disallowed_methods=, but the
; full-feature dynamic NUTAG_ALLOW generation per-handle is DEFERRED. Reasoning:
; chan_sofia uses hardcoded NUTAG_ALLOW string at nua_create which is already
; restrictive (only INVITE/ACK/BYE/CANCEL/OPTIONS/REGISTER/SUBSCRIBE/NOTIFY/
; REFER/MESSAGE/INFO/PUBLISH/PRACK); per-handle dynamic Allow rebuild is ~80-150
; LoC complex per-dialog wire-in with no current operator driver. Future task IF
; operator demand surfaces. STRING-STORAGE SHORTCUT (R5) avoids porting
; mark_parsed_methods + SIP_METHOD_* constants from chan_sip.
;
; chan_sip default is SIP_UNKNOWN bitmask (default DISALLOWS unknown methods);
; chan_sofia default empty string (operator-honest divergence — sofia-sip
; NUTAG_APPL_METHOD handles unknown-method gating natively at NUA layer).
;
;disallowed_methods = PUBLISH,MESSAGE    ; PARSE-COMPAT-ONLY today; effect-deferred

;
; --- contactpermit + contactdeny (post-T56 chan_sip parity, security ACL) ---
; SEPARATE ACL chain applied to peer Contact-header URL host at REGISTER
; processing. Distinct from per-peer permit/deny (Task 32 source-IP ACL):
; operator can have peer registering FROM allowed source-IP but with disallowed
; Contact-IP — hardening against forwarding-via-attacker pattern (peer
; registers Contact: sip:user@attacker.example pointing the registrar at an
; attacker-controlled host).
;
; chan_sip parity at chan_sip.c:28827-28832 (per-peer parser) + L29646-29648
; ([general] parser) + L15043-15044 (apply at REGISTER processing). Verbatim
; ast_append_ha + ast_apply_ha API.
;
; Both per-peer and [general] scope supported (per-peer overrides [general] is
; INCORRECT — chan_sip parity = BOTH apply via short-circuit OR; either DENY rejects).
; Operator scripts copying chan_sip contactpermit/contactdeny migrate verbatim.
;
; KNOWN LIMITATION (Pattern 12 honest-disclosure 11th-instance):
; directmediapermit/directmediadeny per-peer DEFERRED — chan_sip semantic is
; cross-peer cross-leg (peer A's directmediaha gates peer B's RTP remote-addr
; at SDP-processing-time per-medium; chan_sip.c:30362+L30414+L30503+L30561+L30610).
; chan_sofia full-feature wire-in requires SDP-time bridge-partner access at
; sofia_process_invite/reinvite — separate task. PARSE-COMPAT-ONLY ship for
; directmedia ACL keys NOT included this commit (avoids semantic-inverted
; placeholder). Future task IF operator demand surfaces.
;
;contactpermit = 1.2.3.0/24    ; per-peer OR [general]; multi-rule via multiple lines
;contactdeny   = 0.0.0.0/0     ; default-deny then permit specifics

;
; --- directmediapermit + directmediadeny (post-T56 chan_sip parity, cross-peer ACL) ---
; CROSS-PEER CROSS-LEG ACL applied at direct-media decision point: when this
; peer is the BRIDGE PARTNER, refuse direct-media if the OTHER leg's remote
; endpoint is in deny range. chan_sip parity at chan_sip.c:30362-30385
; apply_directmedia_ha verbatim semantic. Per-peer-only (chan_sip [general] ABSENT).
;
; Operator semantic: "peer X has directmediadeny=10.0.0.0/8" means: when X is
; the bridge partner, chan_sofia refuses to bypass itself with direct-media
; if the OTHER leg's remote endpoint is in 10.0.0.0/8 — RTP forced through PBX.
; Use case: peer X is internal trunk; deny direct-media to internal endpoints
; (force PBX to inspect/log/transcode); allow direct-media to public endpoints.
;
; chan_sofia ARCHITECTURAL ADVANTAGE 6th-instance ACTIVE — single
; sofia_get_rtp_peer gate covers all media (audio/video/text/T.38). chan_sip
; applies at 4 process_sdp callouts L30414+L30503+L30561+L30610 per-medium
; duplication; chan_sofia centralized helper catches all callsites at once.
;
; Pattern 12 honest-disclosure 11th-instance CLOSED (deferred from commit
; e9d6cb1 contactpermit/contactdeny ship → implemented this commit).
;
;directmediapermit = 192.168.0.0/16    ; per-peer; multi-rule via multiple lines
;directmediadeny   = 0.0.0.0/0         ; default-deny then permit specifics

;
; --- dnsmgr async DNS hostname-tracking (post-T56 chan_sip parity) ---
; When peer host=hostname (not IP literal), chan_sofia automatically registers an
; async DNS-tracking handle that re-resolves the hostname on a periodic refresh
; schedule. peer->src_addr stays current with upstream gateway DNS changes
; (DDNS hostnames, multi-A-record, failover scenarios). chan_sip parity at
; chan_sip.c:29137-29161 + L13292 callback + L3419-3422 cleanup verbatim.
;
; SYSTEM-WIDE ENABLE: dnsmgr is controlled by res_dnsmgr.so module (dnsmgr.conf).
; chan_sofia has NO per-channel-driver enable key — relies on system-wide dnsmgr
; setting. When dnsmgr is disabled in dnsmgr.conf, chan_sofia peer->dnsmgr stays
; NULL (no refresh handle allocated; behavior identical to pre-this-task).
;
; AUTO-DETECT: peer host=IP-literal (e.g. host=1.2.3.4) → no DNS lookup needed;
; chan_sofia ast_sockaddr_parse pre-check skips dnsmgr registration. peer
; host=hostname (e.g. host=trunk.example.com) → ast_dnsmgr_lookup_cb registers
; refresh handle if dnsmgr enabled.
;
; chan_sofia surpass over chan_sip silent: AMI DnsManagerUpdate event fires on
; every DNS change (Peer:SIP/<name> + OldAddr + NewAddr) for NMS visibility into
; upstream gateway IP changes. chan_sip emits no AMI signal at on_dns_update_peer.
;
; sip show peer "DNS-managed: yes/no" line indicates whether peer has a refresh
; handle active (yes = system-wide dnsmgr enabled AND host is hostname AND lookup
; succeeded; no otherwise).
;
; To enable: configure res_dnsmgr.so via dnsmgr.conf [general] enable=yes +
; refreshinterval=300 (or operator-tuned). Affects ALL gabpbx channel drivers
; that use ast_dnsmgr_* APIs (chan_sip + chan_sofia + others).

;
; --- Dynamic presence hints (post-T56 germanico dynamic hints chan_sip parity) ---
; When a peer has BOTH regexten= AND subscribecontext= configured, chan_sofia
; auto-creates a PRIORITY_HINT extension at peer-load time. The hint extension
; tracks peer presence via DEVICE_STATE(SIP/<peer-name>) so dialplan / SUBSCRIBE
; clients can monitor reachability without manual hint configuration.
;
; Mechanism (mirrors germanico dynamic hints patch at chan_sip.c:5599-5606):
;   - Realtime peers: hint created at sofia_find_peer_realtime conclusion
;     (registrar = "realtime_peer" — chan_sip parity).
;   - Config-file peers (chan_sofia surpass — chan_sip fires realtime-only):
;     hint created at sofia_parse_peer_config conclusion (registrar =
;     "sofia_config_peer" — operator visibility into hint origin via
;     `core show hints` Replace column).
;   - Hint device string: "SIP/<peer->name>" matches chan_sofia AMI events +
;     Dial(SIP/<peer-name>) operator-facing convention. (chan_sip uses
;     peer->username = SIP auth identity; chan_sofia uses peer->name for
;     consistent operator-facing semantic.)
;
; chan_sofia surpass: AMI HintCreated event fires on every hint installation
; (Peer + Extension + Context + HintDevice + Source:realtime|config). chan_sip
; emits no AMI signal at hint creation. NMS systems gain real-time visibility
; into hint lifecycle.
;
; KNOWN LIMITATION (Pattern 12 honest-disclosure): no hint removal counterpart.
; chan_sip relies on ast_context cleanup at module unload; chan_sofia is
; non-unloadable per T40 (sofia-sip same-thread-as-create assert), so dynamic
; hints persist for the chan_sofia module lifetime. Operator restart for hint
; cleanup. This mirrors prior task patterns (cleanup_stale_contexts T40 +
; subscribecontext pivot-deferral + register-TTL Option A dual-scope).
;
; To use: configure both regexten + subscribecontext on the peer (in [peer]
; section or sippeers realtime row); hints auto-install at peer load.
; Example:
;   [alice]
;   regexten=200
;   subscribecontext=hints
;   ; → at peer load: extension '200' added in [hints] context as PRIORITY_HINT
;   ;   pointing at SIP/alice; presence visible via DEVICE_STATE(SIP/alice).

;
; --- MOH per-peer (post-T56 mohinterpret/mohsuggest parity, T26 deferred follow-up) ---
; Default MOH classes for peers without explicit mohinterpret/mohsuggest config.
; mohinterpret = MOH class to play when remote peer puts us on hold (R4
;                ast_moh_start third-arg fallback when peer's mohsuggest absent).
; mohsuggest   = MOH class to suggest to bridged channel when this peer puts us
;                on hold (R5 INBOUND propagation via AST_CONTROL_HOLD data).
;                NOTE: chan_sofia does NOT issue outbound HOLD re-INVITE today,
;                so OUTBOUND-direction Alert-Info mohsuggest signaling is NOT
;                supported (deferred to outbound-HOLD-re-INVITE feature task).
;default_mohinterpret = default
;default_mohsuggest   = default

;
; --- language (post-T56 chan_sip parity, drop-in per-peer audio locale) ---
; Default audio language locale propagated to ast_channel.language for prompts/
; sounds (e.g. en, es, fr, de). Empty default = use gabpbx-core default. Per-peer
; language= overrides this. chan_sip parity chan_sip.c:29709-29710 [general] +
; chan_sip.c:28865-28866 per-peer + chan_sip.c:28447 inheritance. Bounded to
; channel.h:138 MAX_LANGUAGE=40.
;
;language = es

;
; --- parkinglot (post-T56 chan_sip parity, drop-in Park()/transfer routing) ---
; Default parking-lot routing field propagated to ast_channel.parkinglot at
; sofia_new for Park()/transfer-to-park dialplan operations. Per-peer parkinglot=
; overrides this. Default "default" per chan_sip features.h:37
; DEFAULT_PARKINGLOT — chan_sip drop-in.
;
; KNOWN BEHAVIOR CHANGE (Pattern 12 honest-disclosure 16th-instance —
; behavior-change-from-chan_sofia-baseline sub-pattern 2nd-instance, repeats
; maxcallbitrate 14th-instance template): prior chan_sofia baseline emitted
; NO parkinglot on channels (silent-empty default); this task ships chan_sip-
; verbatim "default" string default, so every channel now inherits parkinglot=
; "default" by default. Operators preferring the prior silent-baseline
; restoration set [general] parkinglot= empty explicitly (peers can also
; override via per-peer parkinglot=NAME).
;
;parkinglot = default

;
; --- tos/cos bundle 8-key (post-T56 chan_sip parity, QoS markings) ---
; 8-key bundle for SIP signaling + RTP audio/video/text QoS markings:
;   tos_sip / tos_audio / tos_video / tos_text  ; L3 TOS/DSCP markings
;   cos_sip / cos_audio / cos_video / cos_text  ; L2 802.1p CoS markings
;
; Default 0 for all 8 (no QoS markings). Values accept symbolic (cs3, ef,
; af41, lowdelay) + numeric forms via ast_str2tos / ast_str2cos parsers.
;
; chan_sip parity citations: chan_sip.c:730-737 globals + L29893-29917 8
; [general] parsers + L5888 use site (ast_rtp_instance_set_qos). gabpbx-core
; API at rtp_engine.h:1311.
;
; Wire-in matrix:
;   tos_sip               → TPTAG_TOS at nua_create (sofia-sip native;
;                           Pattern 16 sofia-sip-native 9th-instance)
;   tos_audio + cos_audio → ast_rtp_instance_set_qos on pvt->rtp at sofia_rtp_init
;   tos_video + cos_video → ast_rtp_instance_set_qos on pvt->vrtp (when video)
;   cos_sip               → PARSE-COMPAT-ONLY (sofia-sip TPTAG_COS verified
;                           ABSENT in tport_tag.h grep; full-feature DEFERRED
;                           until upstream surfaces); operators get verbatim
;                           parse-clean migration from chan_sip configs
;   tos_text + cos_text   → PARSE-COMPAT-ONLY (chan_sofia text-RTP infrastructure
;                           ABSENT — no pvt->trtp); future text-RTP wire-in
;                           when chan_sofia adds T.140 support
;
; Production .193 sofia.conf line tos_sip=cs3 + tos_audio=ef + tos_video=af41
; silently-ignored prior to this commit; finally honored on next reload (REAL
; OPERATOR DRIVER consummated).
;
; Operator-honest reload-required note: changing values requires `module reload
; chan_sofia.so` to pick up the new defaults; existing in-flight calls retain
; their original socket-level QoS settings until tear-down.
;
;tos_sip = cs3
;tos_audio = ef
;tos_video = af41
;tos_text = af41
;cos_sip = 3
;cos_audio = 5
;cos_video = 4
;cos_text = 4

;
; --- useragent (post-T56 chan_sip parity, [general] User-Agent/Server header) ---
; User-Agent header value advertised in outbound SIP requests + Server header
; in responses. Default "GABpbx PBX X.Y.Z" (composed at config-load via
; snprintf "%s %s", DEFAULT_USERAGENT, ast_get_version() — chan_sip parity at
; chan_sip.c:29455 + sip.h:219-220 verbatim shape).
;
; Operator customization use cases:
;   * security-hardening — hide server software identification from scanners
;   * brand/version-string operator-policy — replace with operator-branded UA
;   * carrier-fingerprint matching — emulate specific PBX vendor for
;     interoperability with carriers that whitelist by User-Agent
;
; chan_sip parity citations: chan_sip.c:29455 default-init + L29574-29575
; [general] parser + sip.h:219-220 DEFAULT_USERAGENT macro definition.
;
; Pattern 12 22nd-instance behavior-change-from-chan_sofia-baseline-disclosure
; sub-pattern 4th-instance (well past N=3 PROVEN threshold): chan_sofia prior
; to this commit emitted sofia-sip library default "sofia-sip/1.13.17" on
; outbound traffic; this ship overrides with chan_sip-verbatim default for
; drop-in faithfulness — operators copying sip.conf [general] useragent= lines
; to sofia.conf get byte-identical User-Agent header in SIP traces / billing
; systems / fingerprinting tools.
;
; Pattern 16 sofia-sip-native 10th-instance DOUBLE-DIGIT MILESTONE: wire-in
; via SIPTAG_USER_AGENT_STR at nua_create (sip_tag.h:2183 macro). sofia-sip
; emits header on every outbound request + response automatically once tag
; set on nua handle — chan_sofia helper-architecture-advantage 13th-instance
; (single emit-site vs chan_sip 5-site add_header duplication at chan_sip.c
; L11132 response Server + L11307+12986+14331 outbound User-Agent + others).
;
; Production .193 sofia.conf line useragent=Huawei SoftX3000 V300R011
; silently-ignored prior to this commit; finally honored on next reload
; (REAL OPERATOR DRIVER consummated).
;
; Operator-honest reload-required note: changing useragent= requires
; `module reload chan_sofia.so` to pick up the new value; in-flight nua
; handle is destroyed and re-created at reload, so subsequent outbound
; transactions emit the new User-Agent immediately.
;
;useragent = Huawei SoftX3000 V300R011

;
; --- rtp-timeout bundle (post-T56 chan_sip parity, RTP stream no-traffic detection) ---
; 3-key bundle for RTP-stream no-traffic detection + dead-call cleanup +
; periodic keepalive emission. Default 0 for all 3 (disabled).
;   rtptimeout      = N    ; drop call after N seconds without inbound RTP
;   rtpholdtimeout  = N    ; same but for on-hold state (typically larger; calls
;                          ; on hold can sit silent indefinitely otherwise)
;   rtpkeepalive    = N    ; send periodic keepalive RTP packet every N seconds
;
; chan_sip parity citations: chan_sip.c:721-723 globals + L28926-28940 per-peer
; parsers + L29668-29680 [general] parsers + L5862-5864 + L5880-5882 use sites
; (ast_rtp_instance_set_timeout / set_hold_timeout / set_keepalive). gabpbx-core
; APIs at rtp_engine.h:1671 + L1689 + L1707.
;
; Production .193 sofia.conf has rtptimeout=30 + rtpholdtimeout=300 — silently-
; ignored on chan_sofia until this commit lands; finally honored on next reload
; (REAL OPERATOR DRIVER consummated).
;
; Operator-honest reload-required note: changing values requires `module reload
; chan_sofia.so` to pick up the new defaults; existing in-flight calls retain
; their original settings until tear-down.
;
;rtptimeout = 30
;rtpholdtimeout = 300
;rtpkeepalive = 60

;
; --- preferred_codec_only (post-T56 chan_sip parity, SDP codec-list narrowing) ---
; When yes, outbound SDP m=audio offers/answers contain ONLY the single most-
; preferred codec instead of the full enabled-codec list. Use case: bandwidth-
; constrained scenarios + codec-locked trunks (e.g. opus-only) where operator
; wants to lock outbound SDP to a single codec and refuse fallback negotiation.
; Default no per chan_sip drop-in (full codec list offered).
;
; chan_sip parity citations: chan_sip.c:28922-28923 per-peer parser
; ast_set2_flag SIP_PAGE2_PREFERRED_CODEC + L29863-29864 [general] parser
; global_flags[1] + sip.h:313 flag bit + L10076 use site (process_sdp narrows
; pvt->jointcapability via ast_codec_choose).
;
; chan_sofia ARCHITECTURAL ADVANTAGE 12th-instance (Option 6-A chan_sofia-
; strict-direction-symmetric): chan_sip narrows ONLY at process_sdp RESPONSE-
; direction (after computing jointcapability from their offer). chan_sofia
; applies narrowing to BOTH initial-INVITE-offer AND response paths via single
; sofia_generate_sdp helper site — operator semantic preferred_codec_only is
; preserved consistently across both SDP-emit directions (chan_sip slightly
; asymmetric; chan_sofia operator-honest surpass).
;
; Bounded-impact: only when operator explicitly sets the flag (default off).
;
;preferred_codec_only = yes

;
; --- ignoresdpversion (post-T56 chan_sip parity, PARSE-COMPAT-ONLY ship) ---
; chan_sip semantic: when yes, bypass the inbound SDP o-line session-version
; skip-on-no-change gate at process_sdp; treat all SDPs as new and re-process
; regardless of session-version field. Use case: SIP UAs with buggy o= version
; handling that don't bump version on legitimate media changes (without this
; flag chan_sip would skip processing, leaving call media in stale state).
